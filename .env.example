# ============================================================
# BEE HUB — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://your-hub.vercel.app

# Zoho CRM API
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_BASE=https://www.zohoapis.com/crm/v3

# Jobber OAuth App (shared across all locations)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# Resend (transactional + drip emails)
RESEND_API_KEY=

# Cron auth — random secret, set in Vercel project settings. Vercel
# Cron sends "Authorization: Bearer $CRON_SECRET" to /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Stripe webhook (payment links milestone 1) — signing secret from the
# Stripe dashboard webhook endpoint for /api/webhooks/stripe. Without it
# the route rejects every delivery (fail-closed).
STRIPE_WEBHOOK_SECRET=
