# ============================================================
# BEE HUB — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://your-hub.vercel.app

# Zoho CRM API
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_BASE=https://www.zohoapis.com/crm/v3

# Jobber OAuth App (shared across all locations)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
